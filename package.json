{
  "name": "pokefollower-desktop",
  "version": "1.4.0",
  "description": "カーソルを追うポケモンのデスクトップ常駐マスコット (Electron)",
  "author": "naochan3",
  "license": "MIT",
  "main": "src/main/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "electron .",
    "bench:dev-runtime": "node scripts/bench-dev-runtime.cjs",
    "bench:interval": "node scripts/bench-sim-interval.cjs",
    "bench:linux-unpacked-runtime": "node scripts/bench-linux-unpacked-runtime.cjs",
    "bench:mac-unpacked-runtime": "node scripts/bench-mac-unpacked-runtime.cjs",
    "bench:pack-list": "node scripts/bench-pack-list.cjs",
    "bench:search": "node scripts/bench-search-index.cjs",
    "bench:win-unpacked-runtime": "node scripts/bench-win-unpacked-runtime.cjs",
    "evidence:linux-gui": "node scripts/capture-linux-gui-evidence.cjs",
    "evidence:mac-gui": "node scripts/capture-mac-gui-evidence.cjs",
    "test": "vitest run",
    "verify:assets": "node scripts/verify-assets-consistency.cjs",
    "verify:ci": "node scripts/verify-ci-workflow.cjs",
    "verify:deps": "node scripts/verify-dependency-metadata.cjs",
    "verify:docs": "node scripts/verify-docs-consistency.cjs && node scripts/verify-feature-development-governance.cjs",
    "verify:feature-governance": "node scripts/verify-feature-development-governance.cjs",
    "verify:electron": "node scripts/verify-electron-security.cjs",
    "verify:installer": "node scripts/verify-installer-ux.cjs",
    "verify:ipc": "node scripts/verify-ipc-routing.cjs",
    "verify:local": "npm run verify:assets && npm run verify:ci && npm run verify:deps && npm run verify:docs && npm run verify:electron && npm run verify:hygiene && npm run verify:installer && npm run verify:ipc && npm run verify:notification && npm run verify:overlay && npm run verify:platform && npm run verify:runtime-validation && npm run verify:roadmap && npm run verify:runtime && npm run verify:search-metadata && npm run verify:settings && npm run verify:signing && npm run verify:wasm && npm test",
    "verify:hygiene": "node scripts/verify-repo-hygiene.cjs",
    "verify:notification": "node scripts/verify-notification-overlay-render.cjs",
    "verify:overlay": "node scripts/verify-overlay-cache.cjs",
    "verify:platform": "node scripts/verify-platform-support.cjs",
    "verify:release": "node scripts/verify-release-assets.cjs",
    "verify:roadmap": "node scripts/verify-roadmap-issues.cjs",
    "verify:runtime": "node scripts/verify-runtime-guards.cjs",
    "verify:runtime-validation": "node scripts/verify-platform-runtime-validation.cjs",
    "verify:search-metadata": "node scripts/verify-search-metadata.cjs",
    "verify:settings": "node scripts/verify-settings-ui.cjs",
    "verify:signing": "node scripts/verify-signing-status.cjs",
    "verify:wasm": "node scripts/verify-wasm-artifact.cjs",
    "test:rust": "cargo test --manifest-path crates/follower_core/Cargo.toml",
    "bench:sim": "node scripts/bench-sim-interval.cjs",
    "build:rust": "cargo build --manifest-path crates/follower_core/Cargo.toml --release --target wasm32-unknown-unknown && node scripts/copy-rust-core.cjs",
    "dist": "electron-builder --win --x64 --config electron-builder.unsigned.cjs",
    "dist:win": "electron-builder --win --x64 --config electron-builder.unsigned.cjs",
    "dist:win:signed": "electron-builder --win --x64 --config electron-builder.signed.cjs",
    "dist:mac": "electron-builder --mac --config electron-builder.unsigned.cjs",
    "dist:mac:signed": "electron-builder --mac --config electron-builder.signed.cjs",
    "dist:linux": "electron-builder --linux",
    "gen:build": "node scripts/gen-build.mjs",
    "build:index": "node scripts/build-index.mjs"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "fast-xml-parser": "^5.9.3",
    "image-size": "^2.0.2",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "sharp": "^0.35.2"
  },
  "build": {
    "appId": "com.naochan3.pokefollower",
    "productName": "PokeFollower",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "native/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/koffi/**",
      "**/node_modules/@koromix/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.entertainment",
      "icon": "assets/icons/PokeFollower.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "icon": "assets/icons/pokeball-256.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icons/pokeball-256.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "koffi": "^3.0.2"
  }
}
