{
  "name": "pokefollower-desktop",
  "version": "1.0.0",
  "description": "カーソルを追うポケモンのデスクトップ常駐マスコット (Electron)",
  "author": "naochan3",
  "main": "src/main/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:rust": "cargo test --manifest-path crates/follower_core/Cargo.toml",
    "bench:sim": "node scripts/bench-sim-interval.cjs",
    "build:rust": "cargo build --manifest-path crates/follower_core/Cargo.toml --release --target wasm32-unknown-unknown && node scripts/copy-rust-core.cjs",
    "dist": "electron-builder --win --x64",
    "dist:win": "electron-builder --win --x64",
    "dist:win:signed": "electron-builder --win --x64 --config electron-builder.signed.cjs",
    "dist:mac": "electron-builder --mac",
    "dist:mac:signed": "electron-builder --mac --config electron-builder.signed.cjs",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.naochan3.pokefollower",
    "productName": "PokeFollower",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "native/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/koffi/**",
      "**/node_modules/@koromix/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.entertainment",
      "icon": "assets/icons/PokeFollower.icns",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "icon": "assets/icons/pokeball-256.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icons/pokeball-256.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "koffi": "^3.0.2"
  }
}
